<?xml version="1.0" encoding="UTF-8"?>
<!--
  =============================================================================
   CTB UBS — Maven settings.xml
   Project : CTB (Swiss Bank Project) — Server Migration
   Owner   : Sagarika (Technical Lead)

   Place this file at:
     • Linux/macOS : ~/.m2/settings.xml
     • Windows     : C:\Users\<user>\.m2\settings.xml
     • Build agent : referenced via 'mvn -s settings.xml ...'

   ⚠️  Do NOT commit real credentials.
       Use environment variables or Maven master password encryption:
         mvn --encrypt-master-password
         mvn --encrypt-password <password>
  =============================================================================
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0
                              https://maven.apache.org/xsd/settings-1.0.0.xsd">

    <!-- Local Maven repository -->
    <localRepository>${user.home}/.m2/repository</localRepository>

    <!-- ================================================================ -->
    <!--  Servers — credentials for Nexus repositories                     -->
    <!-- ================================================================ -->
    <servers>

        <!-- Nexus releases -->
        <server>
            <id>ctb-ubs-releases</id>
            <username>${env.NEXUS_USER}</username>
            <password>${env.NEXUS_PASS}</password>
        </server>

        <!-- Nexus snapshots -->
        <server>
            <id>ctb-ubs-snapshots</id>
            <username>${env.NEXUS_USER}</username>
            <password>${env.NEXUS_PASS}</password>
        </server>

        <!-- Nexus public (proxy + group) -->
        <server>
            <id>ctb-nexus</id>
            <username>${env.NEXUS_USER}</username>
            <password>${env.NEXUS_PASS}</password>
        </server>

        <!-- Plugin repository -->
        <server>
            <id>ctb-nexus-plugins</id>
            <username>${env.NEXUS_USER}</username>
            <password>${env.NEXUS_PASS}</password>
        </server>

    </servers>

    <!-- ================================================================ -->
    <!--  Mirrors — Route ALL Maven requests through Nexus                 -->
    <!-- ================================================================ -->
    <mirrors>
        <mirror>
            <id>ctb-nexus-mirror</id>
            <name>CTB Nexus Mirror — All</name>
            <url>https://nexus.internal/repository/maven-public/</url>
            <mirrorOf>*,!ctb-ubs-releases,!ctb-ubs-snapshots</mirrorOf>
        </mirror>
    </mirrors>

    <!-- ================================================================ -->
    <!--  Profiles                                                         -->
    <!-- ================================================================ -->
    <profiles>

        <!-- Default profile — points everything at Nexus -->
        <profile>
            <id>ctb-nexus</id>

            <repositories>
                <repository>
                    <id>ctb-nexus</id>
                    <name>CTB Nexus Public</name>
                    <url>https://nexus.internal/repository/maven-public/</url>
                    <releases>
                        <enabled>true</enabled>
                    </releases>
                    <snapshots>
                        <enabled>true</enabled>
                        <updatePolicy>daily</updatePolicy>
                    </snapshots>
                </repository>
            </repositories>

            <pluginRepositories>
                <pluginRepository>
                    <id>ctb-nexus-plugins</id>
                    <name>CTB Nexus Plugin Public</name>
                    <url>https://nexus.internal/repository/maven-public/</url>
                    <releases>
                        <enabled>true</enabled>
                    </releases>
                    <snapshots>
                        <enabled>false</enabled>
                    </snapshots>
                </pluginRepository>
            </pluginRepositories>

            <properties>
                <sonar.host.url>https://sonar.internal</sonar.host.url>
            </properties>
        </profile>

        <!-- Dev1 environment overrides -->
        <profile>
            <id>dev1</id>
            <properties>
                <env>dev1</env>
                <api.url>https://api.dev1.ctb.internal</api.url>
                <agnes.realm>CTB.INTERNAL</agnes.realm>
                <ags.endpoint>https://ags.internal/v1/validate</ags.endpoint>
                <gsr.endpoint>https://gsr.internal/v1/lookup</gsr.endpoint>
                <mers.endpoint>https://mers.internal/events</mers.endpoint>
            </properties>
        </profile>

    </profiles>

    <!-- ================================================================ -->
    <!--  Active profiles                                                  -->
    <!-- ================================================================ -->
    <activeProfiles>
        <activeProfile>ctb-nexus</activeProfile>
    </activeProfiles>

    <!-- ================================================================ -->
    <!--  Plugin groups                                                    -->
    <!-- ================================================================ -->
    <pluginGroups>
        <pluginGroup>org.sonarsource.scanner.maven</pluginGroup>
        <pluginGroup>org.springframework.boot</pluginGroup>
    </pluginGroups>

</settings>
