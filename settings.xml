<?xml version="1.0" encoding="UTF-8"?>
<!--
  =============================================================================
   CTB UBS — Maven settings.xml
   Project : CTB Integracao .NET Windows Application
   Owner   : Sagarika

   ┌──────────────────────────────────────────────────────────────────────┐
   │  WHY MAVEN settings.xml FOR A .NET PROJECT?                          │
   │                                                                      │
   │  This file authenticates Maven against the enterprise Nexus when     │
   │  the pipeline runs `mvn deploy:deploy-file` to upload the packaged   │
   │  .NET application (ZIP) to Nexus. The .NET build itself uses         │
   │  `dotnet build` and authenticates to the NuGet feed via              │
   │  nuget.config — NOT this file.                                       │
   │                                                                      │
   │  In short:                                                           │
   │    • settings.xml  → upload .NET ZIP to Nexus (Maven repos)          │
   │    • nuget.config  → restore .NET dependencies from Nexus (NuGet)    │
   └──────────────────────────────────────────────────────────────────────┘

   Place at:
     • Linux/macOS : ~/.m2/settings.xml
     • Windows     : C:\Users\<user>\.m2\settings.xml
     • Pipeline    : referenced via 'mvn -s settings.xml ...'

   ⚠️  Placeholders intentional — replace inside enterprise environment only.
       <NEXUS_PUBLIC_URL>  →  internal Nexus public/group repo URL
       <SSO_USERNAME>      →  Nexus upload service account username
       ${password}         →  injected at runtime via Vault / EVA secrets
  =============================================================================
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0
                              https://maven.apache.org/xsd/settings-1.0.0.xsd">

    <!-- ================================================================ -->
    <!--  Mirrors — block any default Maven Central lookups                -->
    <!--  (a .NET-only project shouldn't pull from Maven Central anyway,   -->
    <!--   but this enforces the policy at the build-tool level)           -->
    <!-- ================================================================ -->
    <mirrors>
        <mirror>
            <id>public-library</id>
            <name>Public Library</name>
            <url><NEXUS_PUBLIC_URL>/nexus/content/repositories/public/</url>
            <mirrorOf>central</mirrorOf>
        </mirror>
    </mirrors>

    <!-- ================================================================ -->
    <!--  Servers — credentials for Nexus deploy targets                   -->
    <!--  (Used by mvn deploy:deploy-file when pushing the .NET ZIP)       -->
    <!-- ================================================================ -->
    <servers>

        <!-- Snapshot deploy server (develop / feature branches) -->
        <server>
            <id>deploy-shared-071-snapshot</id>
            <username><SSO_USERNAME></username>
            <password>${password}</password>
        </server>

        <!-- Release deploy server (main / master) -->
        <server>
            <id>deploy-shared-071-release</id>
            <username><SSO_USERNAME></username>
            <password>${password}</password>
        </server>

    </servers>

</settings>
