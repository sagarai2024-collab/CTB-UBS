<?xml version="1.0" encoding="UTF-8"?>
<!--
  =============================================================================
   CTB UBS — POM for .NET Windows Application
   Project    : CTB Integracao API (.NET / Windows)
   Owner      : Sagarika
   ARTIFACT   : CTB_integracao_dotnet_app  (a packaged .NET Windows app)

   ┌──────────────────────────────────────────────────────────────────────┐
   │  WHY MAVEN FOR A .NET PROJECT?                                       │
   │                                                                      │
   │  This pom.xml is NOT used to compile .NET code.                      │
   │  Compilation is done by `dotnet build` / MSBuild in the pipeline.    │
   │                                                                      │
   │  Maven is used ONLY as the upload mechanism, because Nexus is a      │
   │  Maven-style repository. The pipeline runs:                          │
   │                                                                      │
   │     mvn deploy:deploy-file \                                         │
   │       -DgroupId=...        \                                         │
   │       -DartifactId=...     \                                         │
   │       -Dversion=...        \                                         │
   │       -Dpackaging=zip      \                                         │
   │       -Dfile=ctb-app.zip                                             │
   │                                                                      │
   │  …to push the ZIP'd .NET output (containing the MSI / EXE / DLLs)    │
   │  into the enterprise Nexus repository.                               │
   └──────────────────────────────────────────────────────────────────────┘

   ⚠️  Placeholders intentional. Replace inside enterprise environment only.
       <NEXUS_WRITE_URL>  →  internal Nexus write endpoint
  =============================================================================
-->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             https://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <!-- ================================================================ -->
    <!--  Coordinates — .NET Windows APPLICATION (packaged as ZIP)         -->
    <!-- ================================================================ -->
    <groupId>com.ubs.ctb.deploy.application</groupId>           <!-- Nexus Group ID    -->
    <artifactId>CTB_integracao_dotnet_app</artifactId>          <!-- Artifact name     -->
    <version>1.0.0-SNAPSHOT</version>
    <packaging>zip</packaging>                                  <!-- ZIP of bin/ + msi -->

    <name>CTB Integracao .NET Windows Application</name>
    <description>
        CTB Integracao — .NET Windows application package (Swiss bank project).
        ZIP contents: compiled binaries (bin/), MSI installer, configuration,
        deployment scripts. Built by dotnet/MSBuild; uploaded via Maven.
    </description>

    <!-- ================================================================ -->
    <!--  Distribution Management — Nexus targets                          -->
    <!-- ================================================================ -->
    <distributionManagement>

        <!-- Publish release versions here -->
        <repository>
            <id>deploy-shared-071-release</id>
            <url><NEXUS_WRITE_URL>/repository/deploy-shared-071-release/</url>
        </repository>

        <!-- Publish snapshot versions here -->
        <snapshotRepository>
            <id>deploy-shared-071-snapshot</id>
            <url><NEXUS_WRITE_URL>/repository/deploy-shared-071-snapshot/</url>
        </snapshotRepository>

    </distributionManagement>

    <!--
      =================================================================
       NO <dependencies> SECTION
      =================================================================
       This is intentional. Java/Maven dependencies are not needed —
       the .NET app's NuGet packages are managed via `nuget.config`
       in the same repo, separately from this pom.xml.
      -->

</project>
