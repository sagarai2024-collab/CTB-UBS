<?xml version="1.0" encoding="UTF-8"?>
<!--
  =============================================================================
   CTB UBS — Application POM
   Project    : CTB Integracao API (Application)
   Owner      : Sagarika
   ARTIFACT   : api_CTB_integracao_application (NOT puppet module)

   ⚠️  Placeholders are intentional. Replace inside enterprise environment only.
       <NEXUS_WRITE_URL>  →  internal Nexus write endpoint
       <NEXUS_REPO_REL>   →  release   repo id (e.g. deploy-shared-071-release)
       <NEXUS_REPO_SNAP>  →  snapshot  repo id (e.g. deploy-shared-071-snapshot)
  =============================================================================
-->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             https://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <!-- ================================================================ -->
    <!--  Coordinates — APPLICATION (not puppet module)                    -->
    <!-- ================================================================ -->
    <groupId>com.ubs.ctb.deploy.application</groupId>           <!-- Nexus Group ID -->
    <artifactId>api_CTB_integracao_application</artifactId>     <!-- Artifact name  -->
    <version>1.0.0-SNAPSHOT</version>
    <packaging>zip</packaging>

    <name>CTB Integracao Application</name>
    <description>CTB Integracao API — application package (Swiss bank project)</description>

    <!-- ================================================================ -->
    <!--  Distribution Management — Nexus targets                          -->
    <!-- ================================================================ -->
    <distributionManagement>

        <!-- Publish release versions here -->
        <repository>
            <id>deploy-shared-071-release</id>
            <url><NEXUS_WRITE_URL>/repository/deploy-shared-071-release/</url>
        </repository>

        <!-- Publish snapshot versions here -->
        <snapshotRepository>
            <id>deploy-shared-071-snapshot</id>
            <url><NEXUS_WRITE_URL>/repository/deploy-shared-071-snapshot/</url>
        </snapshotRepository>

    </distributionManagement>

</project>
